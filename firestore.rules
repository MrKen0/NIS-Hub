rules_version = '2';

// =============================================================
// NIS Hub — Firestore Security Rules
// =============================================================
// These rules control who can read and write data in the database.
// They run on Firebase's servers — not in your app code.
//
// Role hierarchy:  member < provider < moderator < admin
//   'contributor' is a transitional alias for 'moderator' (backward compat — not newly assigned)
// Roles are stored in the user's Firestore document (users/{uid}.role).
//
// NOTE: We read roles from Firestore documents rather than custom claims
// because the Admin SDK is not yet configured. When it is, we can migrate
// to request.auth.token.role for better performance.
// =============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------
    // Helper functions — reusable checks
    // -------------------------------------------------------

    // Is the request from a signed-in user?
    function isSignedIn() {
      return request.auth != null;
    }

    // Get the current user's profile document
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Does the signed-in user have a specific role?
    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    // Is the user a contributor or admin? (elevated privileges)
    // Retained for any future reference — no longer called directly.
    // Use canModerate() instead, which also covers the 'moderator' role.
    function isContributorOrAdmin() {
      return isSignedIn()
        && (getUserData().role == 'contributor' || getUserData().role == 'admin');
    }

    // Is the user an admin?
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    // Is this the document owner?
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ── Moderation role checks ────────────────────────────────────────────────
    // 'moderator' is the formal role going forward.
    // 'contributor' is retained as a transitional alias: existing contributor-role
    // users keep full moderation privileges without a data migration.
    // New moderation appointments should use 'moderator' only.
    function isModerator() {
      return isSignedIn()
        && getUserData().role in ['moderator', 'contributor', 'admin'];
    }

    // Canonical permission check for all content moderation operations.
    function canModerate() {
      return isModerator();
    }

    // -------------------------------------------------------
    // Users collection
    // -------------------------------------------------------
    match /users/{userId} {
      // Users can read their own profile; contributors/admins can read any
      allow read: if isOwner(userId) || canModerate();

      // Users can create their own profile on first sign-in (onboarding)
      // Role must be "member" and status must be "pending" — no self-promotion
      allow create: if isOwner(userId)
        && request.resource.data.role == 'member'
        && request.resource.data.status == 'pending';

      // Owner can update their own profile BUT cannot change role, status,
      // or onboardingComplete — only an admin can change those.
      // This prevents self-escalation via browser console.
      allow update: if (isOwner(userId)
        && request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status
        && request.resource.data.onboardingComplete == resource.data.onboardingComplete)
        || isAdmin();

      // Only admins can delete user profiles
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------
    // Product Listings collection
    // -------------------------------------------------------
    match /productListings/{productId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid;

      // Two strictly field-scoped owner-update paths to prevent self-escalation:
      //
      // 1. Owner EDIT: content fields may change; status is forced to 'pending'.
      //    authorId and createdAt are immutable.
      //    Boost timestamps (lastRepublishedAt, surfacedAt) must not change —
      //    owners cannot self-boost by piggybacking on an edit.
      //    Moderation-only fields must not be touched.
      //
      // 2. Owner BOOST: only the three timestamp fields may change.
      //    status, content fields, authorId and createdAt are all frozen.
      //    hasOnly() enforces this at the key level.
      //
      // Moderators / admins retain unrestricted update access.
      allow update: if isSignedIn() && (

        // ── Owner EDIT path ──────────────────────────────────────────────────
        (
          resource.data.authorId == request.auth.uid
          && request.resource.data.authorId  == resource.data.authorId   // immutable
          && request.resource.data.createdAt == resource.data.createdAt  // immutable
          // Boost timestamps must not change during an edit
          && request.resource.data.lastRepublishedAt == resource.data.lastRepublishedAt
          && request.resource.data.surfacedAt        == resource.data.surfacedAt
          // Status must land on 'pending'
          && request.resource.data.status == 'pending'
          // Moderation-only fields must not be touched by owners
          && !request.resource.data.diff(resource.data)
                .affectedKeys()
                .hasAny(['moderationNote', 'moderatedBy', 'moderatedAt'])
        )

        // ── Owner BOOST path ─────────────────────────────────────────────────
        // Only the three timestamp fields may change; everything else is frozen.
        || (
          resource.data.authorId == request.auth.uid
          && request.resource.data.authorId  == resource.data.authorId   // immutable
          && request.resource.data.createdAt == resource.data.createdAt  // immutable
          && request.resource.data.status    == resource.data.status     // unchanged
          && request.resource.data.diff(resource.data)
                .affectedKeys()
                .hasOnly(['lastRepublishedAt', 'surfacedAt', 'updatedAt'])
        )

        // ── Moderator / admin: unrestricted ──────────────────────────────────
        || canModerate()
      );

      allow delete: if isSignedIn()
        && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    // -------------------------------------------------------
    // Service Listings collection (renamed from services)
    // -------------------------------------------------------
    match /serviceListings/{serviceId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid;

      // Identical two-path field-scoped rule to productListings above.
      allow update: if isSignedIn() && (

        // ── Owner EDIT path ──────────────────────────────────────────────────
        (
          resource.data.authorId == request.auth.uid
          && request.resource.data.authorId  == resource.data.authorId
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.lastRepublishedAt == resource.data.lastRepublishedAt
          && request.resource.data.surfacedAt        == resource.data.surfacedAt
          && request.resource.data.status == 'pending'
          && !request.resource.data.diff(resource.data)
                .affectedKeys()
                .hasAny(['moderationNote', 'moderatedBy', 'moderatedAt'])
        )

        // ── Owner BOOST path ─────────────────────────────────────────────────
        || (
          resource.data.authorId == request.auth.uid
          && request.resource.data.authorId  == resource.data.authorId
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.status    == resource.data.status
          && request.resource.data.diff(resource.data)
                .affectedKeys()
                .hasOnly(['lastRepublishedAt', 'surfacedAt', 'updatedAt'])
        )

        // ── Moderator / admin: unrestricted ──────────────────────────────────
        || canModerate()
      );

      allow delete: if isSignedIn()
        && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    // -------------------------------------------------------
    // Requests collection (community help / tasks / goods)
    // -------------------------------------------------------
    match /requests/{requestId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid;

      allow update: if isSignedIn()
        && (resource.data.authorId == request.auth.uid || canModerate());

      allow delete: if isSignedIn()
        && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    // -------------------------------------------------------
    // Events collection + RSVPs subcollection
    // -------------------------------------------------------
    match /events/{eventId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid;

      // Organiser or contributor/admin can edit
      allow update: if isSignedIn()
        && (resource.data.authorId == request.auth.uid || canModerate());

      allow delete: if isSignedIn()
        && (resource.data.authorId == request.auth.uid || isAdmin());

      // RSVPs — each user manages their own RSVP
      match /rsvps/{userId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }
    }

    // -------------------------------------------------------
    // Notices collection (announcements)
    // -------------------------------------------------------
    match /notices/{noticeId} {
      // All signed-in users can read notices
      allow read: if isSignedIn();

      // Only contributors and admins can create/edit/delete notices
      allow create: if canModerate();
      allow update: if canModerate();
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------
    // Moderation actions log
    // -------------------------------------------------------
    match /moderationActions/{actionId} {
      // Only contributors/admins can read and write moderation logs
      allow read: if canModerate();
      allow create: if canModerate();

      // Moderation records are immutable — no updates or deletes
      allow update: if false;
      allow delete: if false;
    }

    // -------------------------------------------------------
    // Content Policies — keyword blocklist / flaglist
    // -------------------------------------------------------
    // Admin-only: these documents must never be readable from the client.
    // The safety check runs server-side via the Admin SDK in API routes,
    // bypassing these rules entirely. The rules here are a defence-in-depth
    // safeguard to ensure no client can read keyword lists directly.
    match /contentPolicies/{policyId} {
      allow read, write: if isAdmin();
    }

    // -------------------------------------------------------
    // Catch-all: deny everything not explicitly allowed above
    // -------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
